      "playwright": ">=1.58.0",
      "trafilatura": ">=2.0.0",
      "httpx": ">=0.28.0",
      "langchain-anthropic": ">=0.4.0",
      "langchain-core": ">=0.3.0"
    },
    "node": {
      "@monaco-editor/react": "latest",
      "react-split-pane": "latest",
      "react-markdown": "latest",
      "remark-gfm": "latest"
    },
    "infrastructure": {}
  },
  "files": [
    "rag-pipeline/apps/api/src/crawlers/fetcher.py",
    "rag-pipeline/apps/api/src/crawlers/link_discovery.py",
    "rag-pipeline/apps/api/src/converters/markdown_converter.py",
    "rag-pipeline/apps/api/src/workers/crawl_tasks.py",
    "rag-pipeline/apps/api/src/routers/jobs.py",
    "rag-pipeline/apps/api/src/routers/websocket.py",

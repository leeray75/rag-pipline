    { "method": "GET", "path": "/api/v1/ingest/jobs/{job_id}/chunks/{chunk_id}", "response": "ChunkDocument" },
    { "method": "GET", "path": "/api/v1/ingest/jobs/{job_id}/chunk-stats", "response": "ChunkStats" },
    { "method": "POST", "path": "/api/v1/ingest/jobs/{job_id}/embed", "response": "dict" },

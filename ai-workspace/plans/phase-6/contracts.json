            },
            "embed_single": {
              "signature": "def embed_single(self, text: str) -> np.ndarray",
              "description": "Embed a single text string"
            },
            "embed_batched": {
              "signature": "def embed_batched(self, texts: list[str], batch_size: int = 100) -> list[np.ndarray]",
              "description": "Embed texts in batches for memory efficiency"
            }
          }
        }
      },

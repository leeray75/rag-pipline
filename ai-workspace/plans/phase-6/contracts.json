              "signature": "async def ingest_job(self, *, job_id: str, collection_name: str, db: AsyncSession) -> AsyncGenerator[EmbedProgress, None]",
              "description": "Embed and upsert all chunks, yielding progress"
            },
            "get_collection_stats": {
              "signature": "def get_collection_stats(self, collection_name: str) -> dict",
              "description": "Query Qdrant for live collection statistics"
            },

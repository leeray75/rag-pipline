          "type": "class",
          "methods": {
            "__init__": {
              "signature": "def __init__(self, model_name: ModelName = 'BAAI/bge-small-en-v1.5', *, cache_dir: str | None = None, threads: int | None = None) -> None",
              "description": "Initialize with model name"
            },
            "embed_texts": {
              "signature": "def embed_texts(self, texts: list[str]) -> list[np.ndarray]",

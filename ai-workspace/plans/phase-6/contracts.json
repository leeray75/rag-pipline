            "__init__": {
              "signature": "def __init__(self, *, target_tokens: int = 512, max_tokens: int = 1024, overlap_tokens: int = 64, encoding_name: str = 'cl100k_base') -> None",
              "description": "Initialize chunker with token budget parameters"
            },
            "count_tokens": {
              "signature": "def count_tokens(self, text: str) -> int",
              "description": "Return token count for a text string"
            },
            "chunk_document": {
              "signature": "def chunk_document(self, *, markdown: str, document_id: str, job_id: str, metadata: dict | None = None) -> list[Chunk]",
              "description": "Chunk a Markdown document into a list of Chunks"
            }
          }
        }
      },
      "src.ingest.chunking_pipeline": {
        "ChunkingPipeline": {
          "type": "class",
          "methods": {
            "__init__": {
              "signature": "def __init__(self, *, target_tokens: int = 512, max_tokens: int = 1024, overlap_tokens: int = 64) -> None",
              "description": "Initialize pipeline with chunker config"
            },
            "chunk_document": {
              "signature": "async def chunk_document(self, *, document_id: str, job_id: str, markdown_content: str, source_url: str, title: str, description: str, tags: list[str], fetched_at: str | None, approved_at: str | None, audit_rounds: int, quality_score: float, db: AsyncSession) -> list[ChunkDocument]",
              "description": "Chunk a single document and persist"
            },
            "chunk_job": {
              "signature": "async def chunk_job(self, *, job_id: str, approved_documents: list[dict], db: AsyncSession) -> ChunkStats",
              "description": "Chunk all approved documents for a job"
            }
          }
        }
      },

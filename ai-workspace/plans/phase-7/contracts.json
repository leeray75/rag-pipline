    },
    "node": {},
    "infrastructure": {
      "grafana": "grafana/grafana:11.6",
      "tempo": "grafana/tempo:2.7",
      "prometheus": "prom/prometheus:3.4",
      "loki": "grafana/loki:3.5"
    }

    "rag-pipeline/docs/DEPLOYMENT.md"
  ],
  "exports": {
    "python": {
      "src.mcp.server": {
        "mcp": {
          "type": "Server",
          "description": "MCP server instance ('rag-pipeline')"
        },
        "list_tools": {
          "type": "async function",
          "signature": "async def list_tools() -> list[Tool]",
          "description": "Returns 7 MCP tools: ingest_url, get_job_status, list_documents, get_audit_report, search_knowledge_base, approve_job, get_collection_stats"
        }
      },
      "src.mcp.tool_handlers": {
        "call_tool": {
          "type": "async function",
          "signature": "async def call_tool(name: str, arguments: dict) -> list[TextContent]",
          "description": "Routes MCP tool calls to handler functions"
        }
      },
      "src.mcp.sse_transport": {
        "router": {
          "type": "APIRouter",
          "description": "MCP SSE transport router (prefix=/mcp)"
        },
        "sse_transport": {
          "type": "SseServerTransport",
          "description": "SSE transport instance"
        },
        "mcp_sse_endpoint": {
          "type": "async function",
          "signature": "async def mcp_sse_endpoint(request: Request) -> StreamingResponse"
        },
        "mcp_messages_endpoint": {
          "type": "async function",
          "signature": "async def mcp_messages_endpoint(request: Request) -> None"
        }
      },
      "src.auth.jwt_handler": {
        "create_access_token": {
          "type": "function",
          "signature": "def create_access_token(data: dict, expires_delta: timedelta | None = None) -> str"
        },
        "verify_token": {
          "type": "function",
          "signature": "def verify_token(token: str) -> dict"
        }
      },
      "src.auth.dependencies": {
        "get_current_user": {
          "type": "async function",
          "signature": "async def get_current_user(token: str = Depends(oauth2_scheme)) -> dict"
        }
      },
      "src.security.ssrf_prevention": {
        "validate_url": {
          "type": "function",
          "signature": "def validate_url(url: str) -> bool",
          "description": "Validates URL is not targeting internal/private networks"
        },
        "safe_fetch": {
          "type": "async function",
          "signature": "async def safe_fetch(url: str) -> httpx.Response",
          "description": "Fetch URL with SSRF prevention checks"
        }
      },
      "src.security.rate_limiter": {
        "limiter": {
          "type": "Limiter",
          "description": "slowapi rate limiter instance"
        }
      },
      "src.observability.tracing": {
        "init_tracing": {
          "type": "function",
          "signature": "def init_tracing(app: FastAPI) -> None",
          "description": "Initialize OpenTelemetry tracing with Tempo exporter"
        }
      },
      "src.observability.metrics": {
        "init_metrics": {
          "type": "function",
          "signature": "def init_metrics(app: FastAPI) -> None",
          "description": "Initialize Prometheus metrics instrumentation"
        }
      },
      "src.observability.logging_config": {
        "configure_logging": {
          "type": "function",
          "signature": "def configure_logging() -> None",
          "description": "Configure structlog with JSON output for Loki"
        }
      },
      "src.observability.sentry_init": {
        "init_sentry": {
          "type": "function",
          "signature": "def init_sentry(dsn: str | None = None) -> None",
          "description": "Initialize Sentry error tracking"
        }
      }
    },
    "typescript": {}
  },
  "database_tables": [],
  "api_endpoints": [
    { "method": "GET", "path": "/mcp/sse", "response": "SSE stream (MCP protocol)" },
    { "method": "POST", "path": "/mcp/messages/", "response": "MCP message response" },
    { "method": "POST", "path": "/api/v1/auth/token", "response": "JWT access token" },
    { "method": "GET", "path": "/metrics", "response": "Prometheus metrics" }
  ],
  "mcp_tools": [
    {
      "name": "ingest_url",
      "description": "Create an ingestion job from a URL",
      "input": { "url": "string (required)", "crawl_all": "boolean (default: false)" },
      "output": "{ job_id, url, status }"
    },
    {
      "name": "get_job_status",
      "description": "Get current status and progress for a job",
      "input": { "job_id": "string (required)" },
      "output": "{ job_id, status, progress, audit_rounds }"
    },
    {
      "name": "list_documents",
      "description": "List all documents for a job with status",
      "input": { "job_id": "string (required)" },
      "output": "{ job_id, total, documents[] }"
    },
    {
      "name": "get_audit_report",
      "description": "Get structured audit report for a round",
      "input": { "job_id": "string (required)", "round": "integer (default: 1)" },
      "output": "{ job_id, round, report }"
    },
    {
      "name": "search_knowledge_base",
      "description": "Query Qdrant and return ranked chunks",
      "input": { "query": "string (required)", "collection_name": "string (required)", "top_k": "integer (default: 5)" },
      "output": "{ query, collection, results[] }"
    },
    {
      "name": "approve_job",
      "description": "Approve job and start chunking pipeline",
      "input": { "job_id": "string (required)" },
      "output": "{ job_id, task_id, status }"
    },
    {
      "name": "get_collection_stats",
      "description": "Get Qdrant collection metadata and statistics",
      "input": { "collection_name": "string (required)" },
      "output": "{ collection_name, vector_count, status, ... }"
    }
  ],
  "docker_services": [
    "grafana",
    "tempo",
    "prometheus",
    "loki"
  ]
}

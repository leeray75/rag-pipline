      "mcp": ">=1.27.0,<2.0.0",
      "opentelemetry-api": ">=1.33.0,<2.0.0",
      "opentelemetry-sdk": ">=1.33.0,<2.0.0",
      "opentelemetry-instrumentation-fastapi": ">=0.54b0",
      "opentelemetry-instrumentation-celery": ">=0.54b0",
